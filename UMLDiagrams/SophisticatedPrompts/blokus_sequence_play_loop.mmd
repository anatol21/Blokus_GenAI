sequenceDiagram
    actor User
    participant CLI as blokus.cli.cmd_play
    participant TurnLoop as TurnLoopScheduler
    participant PlayerAI as blokus.players
    participant Engine as blokus.engine
    participant State as GameState

    User->>CLI: runPlay(mode, controllers, maxTurns)
    activate CLI
    note right of CLI: REQ-R-F-02: Minimal CLI starts a playable session

    CLI->>Engine: new_game(mode, controllers)
    activate Engine
    note right of Engine: REQ-R-F-01: Configurable engine initializes mode-specific state
    Engine-->>CLI: state: GameState
    deactivate Engine

    loop LOGIC-LOOP-01: each turn until finished or maxTurns reached
        CLI-)TurnLoop: tick(state)
        activate TurnLoop
        note right of TurnLoop: REQ-R-F-10: Repeat turn handling until termination condition is true

        TurnLoop->>State: current_player(), controller_types[current_player]
        activate State
        State-->>TurnLoop: activePlayer: str, controllerType: str
        deactivate State

        alt LOGIC-ALT-02: controllerType == computer
            note right of TurnLoop: REQ-R-F-09: Computer controller executes automated turn selection
            TurnLoop->>PlayerAI: choose_move(state, activePlayer, strategy)
            activate PlayerAI
            PlayerAI->>Engine: list_legal_moves(state, activePlayer)
            activate Engine
            loop LOGIC-LOOP-02: for each remaining piece and transform candidate
                note right of Engine: REQ-R-F-06, REQ-R-F-13: Enumerate legal placements from piece transforms
                Engine->>State: evaluateCandidatePlacement(candidate)
                activate State
                State-->>Engine: candidateLegal: bool
                deactivate State
            end
            Engine-->>PlayerAI: legalMoves: list[Move]
            deactivate Engine
            PlayerAI-->>TurnLoop: selectedMove: Move | None
            deactivate PlayerAI

            alt selectedMove exists
                TurnLoop->>Engine: apply_move(state, selectedMove)
                activate Engine
                note right of Engine: REQ-R-F-05: Apply one validated legal move
                Engine->>Engine: validate_move(state, selectedMove)
                note right of Engine: REQ-R-F-04: Validate move legality before mutation
                Engine-->>TurnLoop: nextState: GameState
                deactivate Engine
            else no legal move
                TurnLoop->>Engine: pass_turn(state, activePlayer)
                activate Engine
                note right of Engine: REQ-R-F-10: Pass only when no legal move exists
                Engine->>Engine: validate_pass(state, activePlayer)
                Engine-->>TurnLoop: nextState: GameState
                deactivate Engine
            end

        else controllerType == human
            note right of TurnLoop: REQ-R-F-08: Human controller receives prompt-driven turn handling
            TurnLoop->>User: promptTurnCommand()

            opt LOGIC-OPT-01: user requests hint/suggestion
                note right of CLI: REQ-R-F-29: Provide optional hint path for stuck players
                User->>CLI: requestHint()
                CLI->>PlayerAI: choose_move(state, activePlayer, strategy)
                activate PlayerAI
                PlayerAI-->>CLI: suggestedMove: Move | None
                deactivate PlayerAI
                CLI-->>User: hintResult: Move | "no legal move"
            end

            opt user requests legal preview
                User->>CLI: legal N
                CLI->>Engine: list_legal_moves(state, activePlayer, limit)
                activate Engine
                loop LOGIC-LOOP-02: for each remaining piece and transform candidate
                    note right of Engine: REQ-R-F-06, REQ-R-F-13: Generate legal options via transformed pieces
                    Engine->>State: evaluateCandidatePlacement(candidate)
                    activate State
                    State-->>Engine: candidateLegal: bool
                    deactivate State
                end
                Engine-->>CLI: legalMoves: list[Move]
                deactivate Engine
                CLI-->>User: legalMovesView: list[Move]
            end

            alt LOGIC-ALT-01: user submits move command
                note right of Engine: REQ-R-F-26, REQ-R-F-27: Validation branches into accept or explain rejection
                User->>CLI: move(piece,x,y,rotation,flipped)
                CLI->>Engine: validate_move(state, move)
                activate Engine
                note right of Engine: REQ-R-F-04: Reject or accept proposed move with reason
                Engine-->>CLI: validation: ValidationResult(ok: bool, reason: str)
                deactivate Engine

                alt validation ok
                    CLI->>Engine: apply_move(state, move)
                    activate Engine
                    note right of Engine: REQ-R-F-05: Persist legal placement and advance turn
                    Engine-->>CLI: nextState: GameState
                    deactivate Engine
                    CLI-->>User: applyAck: str
                    note right of CLI: REQ-R-F-23: Provide clear placement feedback

                    opt LOGIC-OPT-02: practice context and user requests undo
                        note right of CLI: REQ-R-F-28, REQ-R-F-37: Undo is optional and scoped to learning/practice flow
                        User->>CLI: undoLastMove()
                        CLI->>State: restorePreviousState(checkpoint)
                        activate State
                        State-->>CLI: restoredState: GameState
                        deactivate State
                        CLI-->>User: undoAck: str
                    end
                else validation failed
                    CLI-->>User: invalidReason: str
                    note right of CLI: REQ-R-F-27: Explain why move is invalid
                end
            else user submits pass
                User->>CLI: pass
                CLI->>Engine: validate_pass(state, activePlayer)
                activate Engine
                Engine-->>CLI: passValidation: ValidationResult(ok: bool, reason: str)
                deactivate Engine

                alt LOGIC-ALT-03: passValidation.ok == true
                    note right of Engine: REQ-R-F-10: Pass allowed only if no legal move exists
                    CLI->>Engine: pass_turn(state, activePlayer)
                    activate Engine
                    Engine-->>CLI: nextState: GameState
                    deactivate Engine
                    CLI-->>User: passAck: str
                else passValidation.ok == false
                    CLI-->>User: invalidPassReason: str
                end
            end
        end

        TurnLoop-->>CLI: statePrime: GameState
        deactivate TurnLoop
        CLI->>State: finished?
        activate State
        State-->>CLI: isFinished: bool
        deactivate State
    end

    CLI->>User: renderFinalState(state)
    note right of CLI: REQ-R-F-07: Print/serialize resulting game state
    deactivate CLI
